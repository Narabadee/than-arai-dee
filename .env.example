# Copy this file to .env and fill in your Supabase values

# Get this from Supabase > Project Settings > Database > Connection string > URI
# Use the "Transaction" mode URL (port 6543) for serverless/Vercel
DATABASE_URL=postgresql://postgres.YOURPROJECTREF:YOURPASSWORD@aws-0-YOURREGION.pooler.supabase.com:6543/postgres
